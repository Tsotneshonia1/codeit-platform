datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// მომხმარებლის როლები
enum Role {
  STUDENT
  ASSISTANT
  LECTURER
}

// დავალების სტატუსები
enum Status {
  PENDING
  IN_REVIEW
  REVIEWED
  NEEDS_REVISION
  APPROVED
}

// მომხმარებლის მოდელი
model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique // Clerk-ის მომხმარებლის უნიკალური ID
  name        String?
  email       String       @unique
  role        Role         @default(STUDENT)
  image       String?
  
  assignments Assignment[] // მომხმარებლის მიერ გაგზავნილი დავალებები
  feedbacks   Feedback[]   // მომხმარებლის მიერ დაწერილი ფიდბექები
}

// დავალების მოდელი
model Assignment {
  id             String     @id @default(cuid())
  title          String
  githubUrl      String
  liveUrl        String?
  status         Status     @default(PENDING)
  grade          Int?       // ქულა (უკვე გქონდა)
  teacherComment String?    // ახალი: ლექტორის კომენტარი/ფიდბექი
  studentComment String?    // ახალი: სტუდენტის პასუხი ლექტორს
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  // კავშირი მომხმარებელთან (სტუდენტთან)
  student        User       @relation(fields: [studentId], references: [id])
  studentId      String
  
  feedbacks      Feedback[]
}

// ფიდბექის მოდელი (ვტოვებთ ხელუხლებლად სამომავლო, უფრო რთული თრედებისთვის)
model Feedback {
  id           String     @id @default(cuid())
  text         String
  createdAt    DateTime   @default(now())
  
  // რომელ დავალებაზეა ფიდბექი
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  assignmentId String
  
  // ვინ დაწერა ფიდბექი (მასწავლებელმა/ასისტენტმა)
  author       User       @relation(fields: [authorId], references: [id])
  authorId     String
}