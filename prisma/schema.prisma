datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// მომხმარებლის როლები
enum Role {
  STUDENT
  ASSISTANT
  LECTURER
}

// დავალების სტატუსები
enum Status {
  PENDING
  IN_REVIEW
  REVIEWED
  NEEDS_REVISION
  APPROVED
}

model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique // Clerk-ის მომხმარებლის უნიკალური ID
  name        String?
  email       String       @unique
  role        Role         @default(STUDENT)
  image       String?
  
  assignments Assignment[] // მომხმარებლის მიერ გაგზავნილი დავალებები
  feedbacks   Feedback[]   // მომხმარებლის მიერ დაწერილი ფიდბექები
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  githubUrl   String
  liveUrl     String?
  status      Status   @default(PENDING)
  grade       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  student     User     @relation(fields: [studentId], references: [id])
  studentId   String
  
  feedbacks   Feedback[]
}

model Feedback {
  id           String     @id @default(cuid())
  text         String
  createdAt    DateTime   @default(now())
  
  // კასკადური წაშლა, რათა დავალების წაშლისას ესეც წაიშალოს
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  
  author       User       @relation(fields: [authorId], references: [id])
  authorId     String
}